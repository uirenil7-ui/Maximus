rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // USER Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
               && data.email is string 
               && data.email.size() <= 256
               && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128));
      }

      // Role Check: Align get and list permissions to allow leaderboard and profile viewing
      // Note: In a production app, PII (email) should be isolated in a subcollection.
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(userId);
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'overallScore', 'aura', 'achievements', 'streak', 'lastScanDate']);
      
      // SCANS subcollection
      match /scans/{scanId} {
        function isValidScan(data) {
          return data.userId == request.auth.uid
                 && data.photoUrl is string
                 && data.scores is map
                 && data.scores.symmetry is number
                 && data.scores.jawline is number
                 && data.scores.skin is number
                 && data.scores.eyes is number
                 && data.improvementPlan is map;
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(scanId);
        allow create: if isOwner(userId) && isValidScan(incoming());
        // No updates to scans once committed
        allow delete: if isOwner(userId);
      }

      // ROUTINES subcollection
      match /routines/{routineId} {
        function isValidRoutine(data) {
          return data.userId is string 
                 && data.title is string
                 && data.tasks is list;
        }

        function isRoutineOwner(rUserId) {
          return isSignedIn() && request.auth.uid == rUserId;
        }

        allow list: if isRoutineOwner(userId);
        allow get: if isRoutineOwner(userId) && isValidId(routineId);
        allow create: if isRoutineOwner(userId) && isValidRoutine(incoming());
        allow update: if isRoutineOwner(userId) && isValidRoutine(incoming());
        allow delete: if isRoutineOwner(userId);
      }
    }

    // SOCIAL FEED
    match /social_feed/{postId} {
      function isValidPost(data) {
        return data.userId is string 
               && data.score is number
               && data.timestamp is string;
      }

      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(postId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidPost(incoming());
      allow update: if isSignedIn() 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['vouchCount']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
